rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Relaxing for production to avoid email_verified issues while maintaining exact email security
      return isSignedIn() && request.auth.token.email == 'fabioamoriellocontato@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Health Check
    match /health_check/{id} {
      allow read: if true;
    }

    // Community Updates
    match /updates/{updateId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
      
      function isValidUpdate(data) {
        return data.keys().hasAll(['title', 'content', 'date', 'type']) &&
               data.title is string && data.title.size() <= 200 &&
               data.content is string && data.content.size() <= 3000 &&
               data.type in ['update', 'news', 'novelty'];
      }
    }

    // AI Results
    match /ai_results/{resultId} {
      allow read: if true;
      allow create: if isAdmin() && isValidAIResult(incoming());
      allow update: if isAdmin() && isValidAIResult(incoming());
      allow delete: if isAdmin();
      
      function isValidAIResult(data) {
        return data.keys().hasAll(['name', 'currentMonthReturn', 'yearCumulativeReturn', 'status']) &&
               data.name is string && data.name.size() <= 100 &&
               data.currentMonthReturn is number &&
               data.status in ['Active', 'Maintenance', 'Beta'];
      }
    }

    // System Config
    match /config/{configId} {
      allow read: if true;
      allow create: if isAdmin() && isValidConfig(incoming());
      allow update: if isAdmin() && isValidConfig(incoming());
      allow delete: if isAdmin();
      
      function isValidConfig(data) {
        return data.keys().hasAll(['key', 'value']) &&
               data.key is string && data.key.size() <= 100;
      }
    }

    // Push Subscriptions
    match /push_subscriptions/{subId} {
      allow create: if true; // Any user can subscribe
      allow update: if false;
      allow delete: if false; // Only server deletes on error
      allow read: if false; // Only server reads
    }

    // FCM Tokens
    match /fcm_tokens/{tokenId} {
      allow read: if false;
      allow write: if true; // Any user can register their token
    }

    // News AI Cache
    match /news_ai_cache/{cacheId} {
      allow read: if true; // Publicly readable for speed
      allow create, update: if isSignedIn(); // Any signed-in user can trigger generation
      allow delete: if isAdmin();
    }
  }
}
